{
  "$schema": "./.claude/scripts/framework/manifest-schema.json",
  "name": "IDPF Framework",
  "version": "0.85.0",
  "description": "Interactive Development Process Frameworks for AI-assisted software development",
  "created": "2025-11-30",
  "frameworks": [
    "IDPF-Agile",
    "IDPF-Vibe"
  ],
  "domainSpecialists": [
    "Accessibility-Specialist",
    "API-Integration-Specialist",
    "Backend-Specialist",
    "Brand-Strategist",
    "Cloud-Solutions-Architect",
    "Content-Strategist",
    "Database-Engineer",
    "Data-Engineer",
    "Desktop-Application-Developer",
    "DevOps-Engineer",
    "Embedded-Systems-Engineer",
    "Frontend-Specialist",
    "Full-Stack-Developer",
    "Game-Developer",
    "Graphics-Engineer-Specialist",
    "ML-Engineer",
    "Mobile-Specialist",
    "Performance-Engineer",
    "Platform-Engineer",
    "QA-Test-Engineer",
    "Security-Engineer",
    "SRE-Specialist",
    "Systems-Programmer-Specialist",
    "Technical-Writer-Specialist",
    "UX-Designer"
  ],
  "requiredDirectories": [
    "Overview",
    "Assistant",
    "System-Instructions"
  ],
  "excludedFromDeployment": [
    ".gitkeep",
    "precompact-hook.js",
    "test-on-change.js",
    "imported-skills.json",
    "GENERATED.md"
  ],
  "deploymentFiles": {
    "commands": {
      "source": ".claude/commands/",
      "core": [
        "change-domain-expert.md",
        "playwright-check.md"
      ],
      "workflow": [
        "assign-branch.md",
        "bad-test-review.md",
        "code-review.md",
        "switch-branch.md",
        "transfer-issue.md",
        "create-branch.md",
        "prepare-release.md",
        "prepare-beta.md",
        "merge-branch.md",
        "destroy-branch.md",
        "charter.md",
        "extensions.md",
        "create-prd.md",
        "create-backlog.md",
        "design-system.md",
        "complete-prd.md",
        "add-story.md",
        "split-story.md",
        "pivot.md",
        "plan-workstreams.md",
        "work.md",
        "done.md",
        "bug.md",
        "enhancement.md",
        "proposal.md",
        "resolve-review.md",
        "review-issue.md",
        "review-prd.md",
        "review-proposal.md",
        "review-test-plan.md",
        "catalog-screens.md",
        "ci.md",
        "mockups.md",
        "paths.md",
        "audit-commands.md",
        "idpf-stats.md",
        "issue-reset.md"
      ]
    },
    "scripts": {
      "shared": {
        "source": "Templates/scripts/shared/",
        "target": ".claude/scripts/shared/",
        "files": [
          "analyze-commits.js",
          "assign-branch.js",
          "ci-add.js",
          "ci-analyze.js",
          "ci-apply.js",
          "ci-detect-lang.js",
          "ci-detect-workflow.js",
          "ci-hints.js",
          "ci-list.js",
          "ci-modify.js",
          "ci-recommend.js",
          "ci-recommend-ui.js",
          "ci-remove.js",
          "ci-status.js",
          "ci-validate.js",
          "cleanup-artifacts.js",
          "cleanup-release-assets.js",
          "done-verify.js",
          "extensions-cli.js",
          "generate-changelog.js",
          "generate-test-plan.js",
          "plan-workstreams.js",
          "recommend-version.js",
          "switch-branch.js",
          "transfer-issue.js",
          "praxis-diagram-config.js",
          "update-release-notes.js",
          "wait-for-ci.js",
          "ci-watch.js",
          "upgrade-check.js",
          "epic-complexity.js",
          "generate-domain-entities.js",
          "work-preamble.js",
          "done-preamble.js",
          "review-preamble.js",
          "review-finalize.js",
          "review-interdependence.js",
          "review-ac-checkoff.js",
          "paths-preamble.js",
          "resolve-preamble.js",
          "reset-issue-preamble.js",
          "validate-release.js",
          "statusline-check.js",
          "branch-sync-check.js",
          "config-integrity-check.js",
          "mockup-detect-framework.js",
          "mockup-element-extractor.js",
          "mockup-ac-generator.js",
          "mockup-token-styles.js",
          "stats-collect.js"
        ]
      },
      "shared/lib": {
        "source": "Templates/scripts/shared/lib/",
        "target": ".claude/scripts/shared/lib/",
        "files": [
          "gh.js",
          "git.js",
          "load-review-extensions.js",
          "output.js",
          "review-mode.js",
          "active-label.js",
          "issue-type.js",
          "workstream-utils.js",
          "review-format.js",
          "input-validation.js",
          "shell-safe.js",
          "debug.js",
          "framework-config.js",
          "classify-changed-files.js",
          "deployment-scope.js",
          "detect-tech-stack.js",
          "paths-ac-generator.js",
          "dtcg-adapter-loader.js",
          "dtcg-init-builder.js",
          "dtcg-schema.js",
          "dtcg-theme-manager.js",
          "dtcg-token-reader.js",
          "dtcg-tokens.js",
          "schema-driven-questions.js",
          "doc-templates.json",
          "findings-schema.json",
          "qa-config.json",
          "doc-templates-schema.json",
          "qa-config-schema.json"
        ]
      },
      "hooks": {
        "source": "Templates/hooks/",
        "target": ".claude/hooks/",
        "files": [
          "workflow-trigger.js",
          "pre-push",
          "block-cd.js",
          "startup-hook.js",
          "clear-hook.js",
          "resume-hook.js",
          "compact-hook.js"
        ]
      }
    },
    "hooksConfig": [
      {
        "event": "UserPromptSubmit",
        "file": "workflow-trigger.js",
        "timeout": 10
      },
      {
        "event": "PreToolUse",
        "matcher": "Bash",
        "file": "block-cd.js",
        "timeout": 5
      },
      {
        "event": "SessionStart",
        "matcher": "startup",
        "file": "startup-hook.js",
        "timeout": 60
      },
      {
        "event": "SessionStart",
        "matcher": "clear",
        "file": "clear-hook.js",
        "timeout": 5
      },
      {
        "event": "SessionStart",
        "matcher": "resume",
        "file": "resume-hook.js",
        "timeout": 5
      },
      {
        "event": "SessionStart",
        "matcher": "compact",
        "file": "compact-hook.js",
        "timeout": 5
      }
    ],
    "rules": [
      {
        "id": "anti-hallucination-framework",
        "src": "Assistant/Anti-Hallucination-Rules-for-Framework-Development.md",
        "dest": "01-anti-hallucination.md",
        "env": "dev"
      },
      {
        "id": "anti-hallucination-software",
        "src": "Assistant/Anti-Hallucination-Rules-for-Software-Development.md",
        "dest": "01-anti-hallucination.md",
        "env": "deployed"
      },
      {
        "id": "github-workflow",
        "src": "Reference/GitHub-Workflow.md",
        "dest": "02-github-workflow.md",
        "env": "both"
      },
      {
        "id": "session-startup",
        "src": "Reference/Session-Startup-Instructions.md",
        "dest": "03-startup.md",
        "env": "both",
        "framework_only_strip": true
      },
      {
        "id": "deployment-awareness",
        "src": "Reference/Deployment-Awareness.md",
        "dest": "04-deployment-awareness.md",
        "env": "dev"
      },
      {
        "id": "charter-enforcement",
        "src": "Reference/Charter-Enforcement.md",
        "dest": "04-charter-enforcement.md",
        "env": "deployed"
      },
      {
        "id": "windows-shell",
        "src": "Reference/Windows-Shell-Safety.md",
        "dest": "05-windows-shell.md",
        "env": "both",
        "platformOnly": "win32"
      },
      {
        "id": "runtime-triggers",
        "src": "Reference/Runtime-Artifact-Triggers.md",
        "dest": "06-runtime-triggers.md",
        "env": "both"
      },
      {
        "id": "task-creation-timing",
        "src": "Reference/Task-Creation-Timing.md",
        "dest": "07-task-creation-timing.md",
        "env": "dev"
      }
    ],
