{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imported-skills-schema.json",
  "title": "Imported Skills Registry Schema",
  "description": "Schema for .claude/metadata/imported-skills.json — tracks skills imported from idpf-praxis-skills repository via /fw-import-skills",
  "type": "object",
  "required": ["lastUpdated", "count", "skills", "shas"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last import"
    },
    "count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of imported skills"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Sorted list of imported skill directory names"
    },
    "shas": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{40}$"
      },
      "description": "Map of skill name to git commit SHA at time of import"
    }
  },
  "additionalProperties": false
}
