{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extension-recipes-schema.json",
  "title": "Extension Recipes Registry Schema",
  "description": "Schema for .claude/metadata/extension-recipes.json — generated by build-extension-recipes.js from .claude/recipes/",
  "type": "object",
  "required": ["generatedAt", "version", "categories"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "_schema": {
      "type": "object",
      "description": "Inline documentation of the registry structure (not used at runtime)",
      "additionalProperties": true
    },
    "categories": {
      "type": "object",
      "description": "Recipe categories keyed by category ID",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "description", "recipes"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Category display name"
          },
          "description": {
            "type": "string",
            "description": "Category description"
          },
          "recipes": {
            "type": "array",
            "description": "Recipes in this category",
            "items": {
              "type": "object",
              "required": ["name", "description", "extensionPoints", "template"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Recipe identifier"
                },
                "description": {
                  "type": "string",
                  "description": "What this recipe does"
                },
                "extensionPoints": {
                  "type": "array",
                  "description": "Extension point names this recipe targets",
                  "items": { "type": "string" }
                },
                "template": {
                  "type": "string",
                  "description": "Markdown template content injected into extension blocks"
                },
                "prerequisites": {
                  "type": "array",
                  "description": "What must be set up before using this recipe",
                  "items": { "type": "string" }
                },
                "appliesTo": {
                  "type": "array",
                  "description": "Specific command:extension-point combinations (e.g., prepare-release:post-pr-create)",
                  "items": {
                    "type": "string",
                    "pattern": "^[a-z-]+:[a-z-]+$"
                  }
                },
                "technology": {
                  "type": "array",
                  "description": "Technology stack identifiers for filtering. Omit for stack-agnostic recipes.",
                  "items": {
                    "type": "string",
                    "enum": ["node", "python", "go", "rust", "java", "ruby"]
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
