{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "extension-points-schema.json",
  "title": "Extension Points Registry Schema",
  "description": "Schema for .claude/metadata/extension-points.json — generated by build-extension-registry.js",
  "type": "object",
  "required": ["generatedAt", "version", "commandCount", "extensionPointCount", "commands"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "commandCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of extensible commands"
    },
    "extensionPointCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total extension points across all commands"
    },
    "commands": {
      "type": "object",
      "description": "Extensible commands keyed by command name",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "description", "extensionPoints"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["EXTENSIBLE"],
            "description": "Command marker type"
          },
          "description": {
            "type": "string",
            "description": "Command description from frontmatter"
          },
          "extensionPoints": {
            "type": "array",
            "description": "Extension points within this command",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Extension point identifier (e.g., pre-create, post-review)"
                },
                "location": {
                  "type": "string",
                  "description": "Where in the command flow this point executes"
                },
                "purpose": {
                  "type": "string",
                  "description": "What customization this point enables"
                }
              },
              "additionalProperties": false
            }
          },
          "copyright": {
            "type": "string",
            "description": "Copyright notice from frontmatter"
          }
        },
        "additionalProperties": false
      }
    },
    "deprecatedExtensionPoints": {
      "type": "array",
      "description": "Extension points removed or scheduled for removal — px-manager uses this for user notification",
      "items": {
        "type": "object",
        "required": ["command", "name", "deprecatedIn", "reason"],
        "properties": {
          "command": {
            "type": "string",
            "description": "Command that owned the extension point"
          },
          "name": {
            "type": "string",
            "description": "Extension point name"
          },
          "deprecatedIn": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Version when deprecated"
          },
          "removedIn": {
            "type": ["string", "null"],
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Version when removed (null = still present but deprecated)"
          },
          "reason": {
            "type": "string",
            "description": "Why the extension point was deprecated"
          },
          "migrateTo": {
            "type": ["string", "null"],
            "description": "Replacement extension point name, if any"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
