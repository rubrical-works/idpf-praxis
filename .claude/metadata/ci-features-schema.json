{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "ci-features-schema.json",
  "title": "CI Features Schema",
  "description": "Schema for .claude/metadata/ci-features.json — CI feature registry for /ci list and /ci add",
  "type": "object",
  "description": "CI features keyed by feature ID",
  "additionalProperties": {
    "type": "object",
    "required": ["id", "name", "description", "tier", "category", "languages", "detectionPatterns", "template"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "description": { "type": "string" },
      "tier": {
        "type": "string",
        "enum": ["v1", "v2", "v3"],
        "description": "Feature tier (v1 = common, v2 = recommended, v3 = advanced)"
      },
      "category": {
        "type": "string",
        "description": "Feature category (e.g., testing, security, deployment)"
      },
      "languages": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Applicable languages (* = all)"
      },
      "detectionPatterns": {
        "type": "object",
        "description": "Patterns for detecting if feature is already configured",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "template": {
        "type": "object",
        "description": "YAML templates for feature configuration",
        "additionalProperties": { "type": "string" }
      }
    },
    "additionalProperties": false
  }
}
