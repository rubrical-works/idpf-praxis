{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain-signals-schema.json",
  "title": "Domain Signals Schema",
  "description": "Schema for .claude/metadata/domain-signals.json — domain-to-signal mapping for charter-aware domain filtering",
  "type": "object",
  "required": ["version", "description", "domains"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "domains": {
      "type": "object",
      "description": "Domain definitions keyed by domain ID",
      "additionalProperties": {
        "type": "object",
        "required": ["charterKeywords", "alwaysApplicable", "reason"],
        "properties": {
          "charterKeywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fileSignals": {
            "type": "array",
            "items": { "type": "string" }
          },
          "packageSignals": {
            "type": "array",
            "items": { "type": "string" }
          },
          "alwaysApplicable": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
